---
import BaseLayout from '../layouts/BaseLayout.astro';
import { en } from '../i18n/en';
---

<BaseLayout
	messages={en}
	title={`${en.privacy.title} · ${en.brandShort}`}
	description={en.metaDescription}
>
	<main id="main" class="wrap privacy-page">
		<h1 class="heading-lg">{en.privacy.title}</h1>
		<p>{en.privacy.body}</p>
		<p><a href="/">{en.privacy.back}</a></p>
	</main>
</BaseLayout>
