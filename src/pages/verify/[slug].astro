---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CertificateCard from '../../components/CertificateCard.astro';
import { certificates, type Certificate } from '../../data/certificates';
import { en } from '../../i18n/en';

export function getStaticPaths() {
	return certificates.map((certificate) => ({
		params: { slug: certificate.slug },
		props: { certificate },
	}));
}

interface Props {
	certificate: Certificate;
}

const { certificate } = Astro.props;
const title = `${en.verify.metaTitle} · ${certificate.institution} · ${en.brandShort}`;
---

<BaseLayout messages={en} title={title} description={en.verify.intro}>
	<CertificateCard messages={en} certificate={certificate} />
</BaseLayout>
