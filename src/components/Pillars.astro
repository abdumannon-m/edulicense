---
import type { Messages } from '../i18n/types';
import PillarIcon from './PillarIcon.astro';

interface Props {
	messages: Messages;
}

const { messages } = Astro.props;
---

<section class="section section--spacious services-section" id="services" aria-labelledby="pillars-heading">
	<div class="wrap">
		<h2 id="pillars-heading" class="heading-lg heading-lg--center">{messages.pillars.heading}</h2>
		{
			messages.pillars.intro ? (
				<p class="muted intro-center">{messages.pillars.intro}</p>
			) : null
		}
		<div class="pillar-grid">
			{
				messages.pillars.items.map((item) => (
					<article class="pillar-card">
						<div class="pillar-card__icon" aria-hidden="true">
							<PillarIcon name={item.icon} />
						</div>
						<h3 class="pillar-card__title">{item.title}</h3>
						<p class="pillar-card__tagline">{item.tagline}</p>
					</article>
				))
			}
		</div>
	</div>
</section>
