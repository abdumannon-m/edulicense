---
import type { Messages } from '../i18n/types';
import type { Certificate } from '../data/certificates';

interface Props {
	messages: Messages;
	certificate: Certificate;
}

const { messages, certificate } = Astro.props;
const v = messages.verify;
const homePath = messages.lang === 'uz' ? '/uz' : '/';

const details = [
	{ label: v.satDate, value: certificate.satAdministrationDate },
	{ label: v.verificationId, value: certificate.verificationId, mono: true },
	{ label: v.issueDate, value: certificate.issueDate },
];
---

<main id="main" class="verify-page">
	<div class="wrap wrap--narrow">
		<article class="cert">
			<header class="cert__top">
				<span class="cert__brand">{messages.brandShort}</span>
				<span class="cert__badge">
					<svg viewBox="0 0 16 16" aria-hidden="true" class="cert__badge-icon">
						<path
							d="M4 8.5l2.5 2.5L12 5"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
						/>
					</svg>
					{v.badge}
				</span>
			</header>

			<h1 class="cert__heading">{v.heading}</h1>
			<p class="cert__intro">{v.intro}</p>

			<div class="cert__institution">
				<p class="cert__inst-name">{certificate.institution}</p>
				<p class="cert__inst-role">{certificate.designation}</p>
			</div>

			<dl class="cert__details">
				{
					details.map((row) => (
						<div class="cert__detail">
							<dt>{row.label}</dt>
							<dd class={row.mono ? 'cert__detail-mono' : undefined}>{row.value}</dd>
						</div>
					))
				}
			</dl>

			<figure class="cert__shot">
				<figcaption class="cert__shot-head">{v.screenshotHeading}</figcaption>
				<img
					src={certificate.collegeBoardScreenshot}
					alt={`${v.screenshotHeading} — ${certificate.institution}`}
					width="880"
					height="540"
					loading="lazy"
					decoding="async"
				/>
				<figcaption class="cert__shot-cap">{v.screenshotCaption}</figcaption>
			</figure>

			<div class="cert__attest">
				<div class="cert__seal-wrap">
					<svg class="cert__seal" viewBox="0 0 160 160" aria-hidden="true">
						<defs>
							<path id="seal-arc-top" d="M 16 80 A 64 64 0 0 1 144 80" />
							<path id="seal-arc-bottom" d="M 144 80 A 64 64 0 0 1 16 80" />
						</defs>
						<circle cx="80" cy="80" r="75" fill="none" stroke="currentColor" stroke-width="1.4" />
						<circle cx="80" cy="80" r="61" fill="none" stroke="currentColor" stroke-width="1" />
						<text class="cert__seal-arc">
							<textPath href="#seal-arc-top" startOffset="50%" text-anchor="middle">
								{v.sealTop}
							</textPath>
						</text>
						<text class="cert__seal-arc">
							<textPath href="#seal-arc-bottom" startOffset="50%" text-anchor="middle">
								{v.sealBottom}
							</textPath>
						</text>
						<circle cx="80" cy="80" r="26" fill="currentColor" />
						<path
							d="M70 80.5l6.5 6.5L92 71"
							fill="none"
							stroke="#fff"
							stroke-width="3.4"
							stroke-linecap="round"
							stroke-linejoin="round"
						/>
					</svg>
				</div>
				<div class="cert__signature">
					<svg class="cert__sig-mark" viewBox="0 0 220 64" aria-hidden="true">
						<path
							d="M14 46 q14 -42 28 -10 q7 20 15 2 q11 -24 24 6 q7 17 17 -3 q13 -27 27 1 q9 15 22 -7 q15 -24 33 9"
							fill="none"
							stroke="currentColor"
							stroke-width="2.4"
							stroke-linecap="round"
						/>
						<path
							d="M10 56 q104 17 200 -5"
							fill="none"
							stroke="currentColor"
							stroke-width="1.4"
							stroke-linecap="round"
						/>
					</svg>
					<span class="cert__signature-name">{messages.brandLegal}</span>
					<span class="cert__signature-label">{v.signatureLabel}</span>
				</div>
			</div>

			<p class="cert__note">{v.footerNote}</p>
		</article>

		<p class="verify-back">
			<a href={homePath}>{'←'} {v.backHome}</a>
		</p>
	</div>
</main>
