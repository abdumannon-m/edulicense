---
import type { Messages } from '../i18n/types';
import { whatsappUrl } from '../i18n/contact';

interface Props {
	messages: Messages;
}

const { messages } = Astro.props;
const wa = whatsappUrl(messages.hero.whatsappPrefill);
const home = messages.lang === 'uz' ? '/uz' : '/';

const heroSrc =
	'https://images.unsplash.com/photo-1503676260728-1c00da094a0b?auto=format&fit=crop&w=960&q=80';
---

<section class="hero" aria-labelledby="hero-title">
	<div class="wrap hero__grid">
		<div class="hero__copy">
			<h1 id="hero-title" class="heading-xl">{messages.hero.title}</h1>
			<p class="hero__subtitle">{messages.hero.subtitle}</p>
			<div class="hero__actions">
				<a class="btn btn--primary btn--hero" href={wa} rel="noopener noreferrer" target="_blank">
					{messages.hero.cta}
				</a>
				<a class="hero__link" href={`${home}#services`}>{messages.hero.scrollHint}</a>
			</div>
		</div>
		<figure class="hero__figure">
			<img
				class="hero__img"
				src={heroSrc}
				alt={messages.hero.imageAlt}
				width="960"
				height="720"
				loading="eager"
				decoding="async"
				fetchpriority="high"
			/>
			<figcaption class="hero__credit">{messages.footer.creditPhoto}</figcaption>
		</figure>
	</div>
</section>
