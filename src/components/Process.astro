---
import type { Messages } from '../i18n/types';

interface Props {
	messages: Messages;
}

const { messages } = Astro.props;
---

<section class="section" id="process" aria-labelledby="process-heading">
	<div class="wrap">
		<h2 id="process-heading" class="heading-lg">{messages.process.heading}</h2>
		<div class="process" style="margin-top: 1.5rem;">
			{
				messages.process.steps.map((step) => (
					<div class="process__step">
						<strong>{step.title}</strong>
						<span class="muted" style="font-size: 0.98rem;">
							{step.body}
						</span>
					</div>
				))
			}
		</div>
	</div>
</section>
