---
import type { Messages } from '../i18n/types';

interface Props {
	messages: Messages;
}

const { messages } = Astro.props;
---

<section class="section section--tight faq-section" id="faq" aria-labelledby="faq-heading">
	<div class="wrap wrap--narrow">
		<h2 id="faq-heading" class="heading-lg">{messages.faq.heading}</h2>
		<p class="muted intro-copy">{messages.faq.intro}</p>
		<div class="faq faq--minimal">
			{
				messages.faq.items.map((item) => (
					<details class="faq__item">
						<summary>{item.question}</summary>
						<p>{item.answer}</p>
					</details>
				))
			}
		</div>
	</div>
</section>
<script>
	document.querySelectorAll('.faq--minimal').forEach((faq) => {
		faq.addEventListener('toggle', (event) => {
			const item = event.target;
			if (!(item instanceof HTMLDetailsElement) || !item.open) return;
			faq.querySelectorAll('details[open]').forEach((openItem) => {
				if (openItem !== item) openItem.removeAttribute('open');
			});
		}, true);
	});
</script>
