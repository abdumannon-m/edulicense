---
import type { Messages } from '../i18n/types';

interface Props {
	messages: Messages;
}

const { messages } = Astro.props;
---

<section class="section section--tight" id="faq" aria-labelledby="faq-heading">
	<div class="wrap wrap--narrow">
		<h2 id="faq-heading" class="heading-lg">{messages.faq.heading}</h2>
		<p class="muted intro-copy">{messages.faq.intro}</p>
		<div class="faq faq--open">
			{
				messages.faq.items.map((item) => (
					<article class="faq__item">
						<h3>{item.question}</h3>
						<p>{item.answer}</p>
					</article>
				))
			}
		</div>
	</div>
</section>
