---
import type { Messages } from '../i18n/types';

interface Props {
	messages: Messages;
}

const { messages } = Astro.props;
---

<section class="section section--tight section--surface" id="why" aria-labelledby="why-heading">
	<div class="wrap wrap--narrow">
		<h2 id="why-heading" class="heading-lg">{messages.why.heading}</h2>
		<p class="lead">{messages.why.body}</p>
	</div>
</section>
