{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/api/app?path=/admin"
    },
    {
      "source": "/admin/:path*",
      "destination": "/api/app?path=/admin/:path*"
    },
    {
      "source": "/verify/:path*",
      "destination": "/api/app?path=/verify/:path*"
    },
    {
      "source": "/uz/verify/:path*",
      "destination": "/api/app?path=/uz/verify/:path*"
    }
  ]
}
