# Go service
ADDR=:8080
APP_BASE_URL=https://www.edulicense.uz
APP_TIMEZONE=Asia/Tashkent
SESSION_SECRET=replace-with-a-long-random-secret
COOKIE_SECURE=true

# Postgres. DATABASE_URL is preferred; POSTGRES_URL is also accepted on Vercel.
DATABASE_URL=postgres://user:password@localhost:5432/edu_license?sslmode=disable

# Private S3/R2-compatible document storage
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto

# Telegram reminder notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_OPERATIONS_CHAT_ID=

# One-time first super admin seed
SEED_ADMIN_NAME=Edu License Owner
SEED_ADMIN_EMAIL=owner@edulicense.uz
SEED_ADMIN_PASSWORD=change-this-password
